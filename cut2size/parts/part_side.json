      "valueScript": "let Drill = this.addncout_DrillVert();\n\n  // StandardValue\n  Drill.nc_TOOL = \"102\";\n  Drill.nc_XA = partSelf._dimy - posRel.y - (part2.pa_Diameter / 2);\n  Drill.nc_YA = partSelf._dimz - posRel.z - (part2.pa_Diameter / 2);\n  Drill.nc_AN = 1;\n  Drill.nc_Side = \"Left\";\n  Drill.nc_MprRelevant = true;\n  Drill.nc_DrawingRelevant = true;\n\n\n  // AttributeValues\n\n  Drill.nc_TI = part2.pa_DrillDepth;\n  Drill.nc_DU = part2.pa_Diameter;\n  Drill.nc_BM = part2.pa_DrillDepth >= partSelf._thickness ? \"LSL\" : \"LS\";\n  Drill.nc_WI = 0;\n  Drill.nc_AB = 1;\n  //Drill.nc_LA = 0;\n  Drill.nc_MI = 0;\n  Drill.nc_KO = \"00\";",
